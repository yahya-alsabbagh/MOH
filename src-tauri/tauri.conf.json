{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOH-Auth-System",
  "version": "2.0.0",
  "identifier": "com.moh.auth",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "publisher": "Ministry of Health",
    "license": "./license.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  },
  "app": {
    "windows": [
      {
        "title": "نظام التدقيق الرقمي الذكي",
        "width": 1150,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
